# Path to the ECDICT stardict.db SQLite file.
# Either point this at wherever you downloaded it, or move/copy the file to
# server/data/stardict.db and delete this line to fall back to that default.
DICT_DB_PATH=C:\path\to\stardict.db

# Port the Express server listens on (defaults to 3001).
PORT=3001

# Set to "production" to serve the built client from client/dist.
NODE_ENV=development
